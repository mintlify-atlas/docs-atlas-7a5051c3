  "keyFeatures": [
    "Real-time streaming of Solana accounts, transactions, blocks, and slots",
    "High-performance gRPC interface with compression support",
    "Advanced filtering by account, owner, transaction signature, and custom memcmp",
    "Multiple client SDKs (Rust, TypeScript/Node.js) with examples for Go and Python",
    "Configurable subscription limits and filter constraints",
    "Block reconstruction with detailed transaction and account data",
    "Deshred transactions streaming for pre-execution data",
    "Unary methods for queries (GetLatestBlockhash, GetBlockHeight, etc.)",
    "Prometheus metrics and monitoring support"
  ],
  "publicApiSurface": [
    "Subscribe - Streaming RPC for real-time blockchain data",
    "SubscribeDeshred - Streaming RPC for deshred transactions",
    "Ping - Check server connectivity",
    "GetLatestBlockhash - Get latest blockhash",
    "GetBlockHeight - Get current block height",
    "GetSlot - Get current slot",
    "IsBlockhashValid - Validate blockhash",
    "GetVersion - Get server version",
    "SubscribeReplayInfo - Get replay information",
    "GeyserGrpcClient (Rust) - Main client struct",
    "Client (TypeScript) - Main client class",
    "SubscribeRequest - Configure subscriptions with filters",
    "SubscribeUpdate - Receive account/transaction/block/slot updates",
    "CommitmentLevel - Processed/Confirmed/Finalized",
    "Filter types - Accounts, Transactions, Blocks, Slots, Entries"
  ]
